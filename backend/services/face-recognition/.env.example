# PhotoPro Face Recognition Service – Environment Configuration
# Copy to .env and fill in real values.

# ── Service ───────────────────────────────────────────────────────────────────
APP_NAME=PhotoPro Face Recognition Service
APP_VERSION=1.0.0
DEBUG=false

# ── AWS Credentials ───────────────────────────────────────────────────────────
# IAM permissions required: rekognition:IndexFaces, rekognition:SearchFacesByImage,
# rekognition:CreateCollection, rekognition:DescribeCollection
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_ACCESS_KEY>

# ── Rekognition Collection ────────────────────────────────────────────────────
# All face vectors are stored in this single collection.
# Create it on first run (ensure_collection is called at startup).
REKOGNITION_COLLECTION_ID=photopro-prod

# ── S3 ────────────────────────────────────────────────────────────────────────
# Same bucket as the main PhotoPro backend – used when fetching images to index.
S3_BUCKET=photopro-prod

# ── Redis (search result caching) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# ── Face matching defaults ────────────────────────────────────────────────────
FACE_SIMILARITY_THRESHOLD=85.0
MAX_FACES_PER_IMAGE=20

# ── Upload limits ─────────────────────────────────────────────────────────────
# MAX_IMAGE_BYTES: Rekognition hard limit before we resize (keep at 5 MB)
# MAX_UPLOAD_SIZE: what the API accepts from clients
MAX_IMAGE_BYTES=5242880
MAX_UPLOAD_SIZE=20971520

# ── API ───────────────────────────────────────────────────────────────────────
API_PREFIX=/api/v1
# Comma-separated origins. Use specific domains in production.
CORS_ORIGINS=http://localhost:8000,https://api.102photo.trip360.vn

# ── Security ──────────────────────────────────────────────────────────────────
# Must match FACE_SERVICE_API_KEY in the PhotoPro backend .env
SERVICE_API_KEY=<CHANGE_THIS_TO_A_SHARED_SECRET>
