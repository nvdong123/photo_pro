ENV=development
APP_URL=http://localhost:8000
# Frontend domain (leave empty in dev to reuse APP_URL for redirects)
FRONTEND_URL=
DEBUG=true

DATABASE_URL=postgresql+asyncpg://photopro:photopro_dev@localhost:5433/photopro
REDIS_URL=redis://localhost:6379/0

# For local dev with MinIO (docker-compose): use minioadmin / minioadmin
# For production: use real AWS credentials
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=ap-southeast-1
S3_BUCKET=photopro-v1
# S3-compatible endpoint – set to MinIO URL for local dev, leave empty for real AWS S3
S3_ENDPOINT_URL=http://localhost:9000

FACE_SERVICE_URL=http://localhost:8001
FACE_SERVICE_API_KEY=internal-secret

UPLOAD_SCAN_FOLDER=/photopro_upload
UPLOAD_ROOT=/photopro_upload
WATERMARK_PATH=./assets/watermark.png

VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8000/api/v1/payment/vnpay/return
VENO_BASE_URL=http://localhost:8080
VENO_SYNC_SECRET=change_me_random_32_chars

RESEND_API_KEY=
EMAIL_FROM=noreply@photopro.vn

JWT_SECRET=change_this_in_production
JWT_EXPIRE_HOURS=168

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

INITIAL_ADMIN_EMAIL=admin@photopro.vn
INITIAL_ADMIN_PASSWORD=change_me
