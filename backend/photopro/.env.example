ENV=development
APP_URL=http://localhost:8000
# Frontend domain (leave empty in dev to reuse APP_URL for redirects)
FRONTEND_URL=
DEBUG=true

DATABASE_URL=postgresql+asyncpg://photopro:photopro_dev@localhost:5433/photopro
REDIS_URL=redis://localhost:6379/0

# For local dev with MinIO (docker-compose): use minioadmin / minioadmin
# For production: use real AWS credentials
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=ap-southeast-1
S3_BUCKET=photopro-v1
# S3-compatible endpoint – set to MinIO URL for local dev, leave empty for real AWS S3
S3_ENDPOINT_URL=http://localhost:9000

# Cloudflare R2 CORS – required for direct browser→R2 presigned PUT uploads.
# Create an API Token with R2:Edit permission at dash.cloudflare.com/profile/api-tokens.
# Leave empty for local dev (MinIO does not need this).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

FACE_SERVICE_URL=http://localhost:8001
FACE_SERVICE_API_KEY=internal-secret

WATERMARK_PATH=./assets/watermark.png

VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8000/api/v1/payment/vnpay/return

# PayOS (https://payos.vn)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

RESEND_API_KEY=
EMAIL_FROM=noreply@photopro.vn

JWT_SECRET=change_this_in_production
JWT_EXPIRE_HOURS=168

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# FTP server (for camera WiFi upload)
FTP_ENABLED=true
FTP_PUBLIC_IP=157.10.199.22        # your VPS public IP or domain (required for PASV behind NAT)
FTP_PORT=21
FTP_PASSIVE_PORTS_START=21000
FTP_PASSIVE_PORTS_END=21099

INITIAL_ADMIN_EMAIL=admin@photopro.vn
INITIAL_ADMIN_PASSWORD=change_me

# Temporary: set to true to bypass all payment providers (testing only)
# When SKIP_PAYMENT=true:
#   - Ignores all payment gateways (VNPay, PayOS, MoMo, Bank)
#   - Marks orders PAID immediately after checkout
#   - Sends download link without requiring payment
# Use ONLY for testing. Set to false in production.
SKIP_PAYMENT=false
