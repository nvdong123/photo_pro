# ─── PhotoPro Root .env.example ──────────────────────────────────────────────
# Copy to .env and fill in real values for each sub-project.
# Per-service .env.example files are in:
#   backend/photopro/.env.example
#   backend/services/face-recognition/.env.example

# Backend (see backend/photopro/.env.example for full list)
ENV=development
DATABASE_URL=postgresql+asyncpg://photopro:photopro_dev@localhost:5433/photopro
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change_this_in_production
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=photopro-v1
S3_ENDPOINT_URL=http://localhost:9000
FACE_SERVICE_URL=http://localhost:8001
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
RESEND_API_KEY=
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:8000
